<Window x:Class="GraveAgency.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GraveAgency"
        mc:Ignorable="d"
         Title="Гробовое агентство" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#000000"
        FontFamily="Times New Roman">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1a1a1a" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="⚰️ ГРОБОВОЕ АГЕНТСТВО &quot;ВЕЧНЫЙ ПОКОЙ&quot; ⚰️" 
                           FontSize="18" FontWeight="Bold" Foreground="#800080"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="Пользователь: " Foreground="#888888" VerticalAlignment="Center"/>
                    <TextBlock x:Name="txtUserName" Foreground="#800080" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,15,0"/>
                    <Button x:Name="btnLogout" Content="ВЫЙТИ" Background="#660000" Foreground="White"
                            Padding="10,5" FontSize="12" Cursor="Hand" BorderThickness="0"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="#333333" Padding="5">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="btnCatalog" Content="📦 КАТАЛОГ" Background="#800080" Foreground="White"
                        Padding="20,10" Margin="5" FontSize="14" FontWeight="Bold" Cursor="Hand"/>
                <Button x:Name="btnCart" Content="🛒 КОРЗИНА" Background="#800080" Foreground="White"
                        Padding="20,10" Margin="5" FontSize="14" FontWeight="Bold" Cursor="Hand"/>
                <Button x:Name="btnProfile" Content="👤 ПРОФИЛЬ" Background="#800080" Foreground="White"
                        Padding="20,10" Margin="5" FontSize="14" FontWeight="Bold" Cursor="Hand"/>
                <Button x:Name="btnNecromancer" Content="🔮 НЕКРОМАНТ" Background="#800080" Foreground="White"
                        Padding="20,10" Margin="5" FontSize="14" FontWeight="Bold" Cursor="Hand"/>
                <Button x:Name="btnAdmin" Content="⚙️ АДМИН" Background="#800080" Foreground="White"
                        Padding="20,10" Margin="5" FontSize="14" FontWeight="Bold" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="#0a0a0a" Margin="10" CornerRadius="10" Cursor="">
            <Frame x:Name="MainContent"/>
        </Border>

        <TextBlock Grid.Row="3" Text="© 2025 Гробовое агентство с гарантией воскресения | С нами надежно даже после смерти"
                   FontSize="11" Foreground="#444444" HorizontalAlignment="Center" Margin="0,10"/>
    </Grid>
</Window>
