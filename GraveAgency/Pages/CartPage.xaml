<Page x:Class="GraveAgency.Pages.CartPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GraveAgency.Pages"
        mc:Ignorable="d"
         Title="Корзина" Background="#0a0a0a"
      FontFamily="Times New Roman">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="КОРЗИНА" FontSize="24" FontWeight="Bold" 
                   Foreground="#800080" HorizontalAlignment="Center" Margin="0,0,0,15"/>

        <DataGrid x:Name="dgCart" Grid.Row="1" Background="#1a1a1a" Foreground="White"
                  BorderBrush="#800080" AutoGenerateColumns="False" Margin="0,0,0,10"
                  HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding CoffinID}" Width="50"/>
                <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="200"/>
                <DataGridTextColumn Header="Материал" Binding="{Binding Material}" Width="120"/>
                <DataGridTextColumn Header="Кнопка" Binding="{Binding ButtonText}" Width="120"/>
                <DataGridTextColumn Header="Цена" Binding="{Binding Price, StringFormat={}{0:C}}" Width="100"/>
                <DataGridTemplateColumn Header="Действия" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="УДАЛИТЬ" Background="#660000" Foreground="White"
                                    Padding="5" FontSize="10" Cursor="Hand"
                                    Tag="{Binding}" Click="BtnRemoveFromCart_Click"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="2" Background="#1a1a1a" Padding="10" CornerRadius="5" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="ИТОГО: " Foreground="White" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock x:Name="txtTotal" Foreground="#800080" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="btnClearCart" Content="ОЧИСТИТЬ КОРЗИНУ" Background="#444444" Foreground="White"
                            Padding="15,10" Margin="5" FontSize="14" Cursor="Hand"/>
                    <Button x:Name="btnCheckout" Content="ОФОРМИТЬ ЗАКАЗ" Background="#800080" Foreground="White"
                            Padding="15,10" Margin="5" FontSize="14" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>

        <TextBlock x:Name="txtEmptyCart" Grid.Row="3" Text="Корзина пуста" FontSize="14" 
                   Foreground="#666666" HorizontalAlignment="Center" Visibility="Collapsed"/>
    </Grid>
</Page>
