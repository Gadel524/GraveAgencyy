<Page x:Class="GraveAgency.Pages.AdminPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GraveAgency.Pages"
        mc:Ignorable="d"
        Title="Панель администратора" Background="#0a0a0a"
      FontFamily="Times New Roman">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="ПАНЕЛЬ АДМИНИСТРАТОРА" FontSize="24" FontWeight="Bold" 
                   Foreground="#800080" HorizontalAlignment="Center" Margin="0,0,0,15"/>

        <TabControl Grid.Row="1" Background="#1a1a1a" Foreground="White" 
                    BorderBrush="#800080" FontSize="14">

            <TabItem Header="👥 ПОЛЬЗОВАТЕЛИ" Background="#333333" Foreground="White">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#1a1a1a" Padding="10" CornerRadius="5" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="txtUserSearch" Grid.Column="0" Background="#333333" Foreground="White"
                                     BorderBrush="#800080" BorderThickness="1" Padding="8" FontSize="14"
                                     Tag="Поиск по логину..."/>

                            <Button x:Name="btnSearchUser" Grid.Column="1" Content="ПОИСК" Background="#800080" 
                                    Foreground="White" Padding="15,8" Margin="10,0,0,0" FontSize="12" Cursor="Hand"/>
                        </Grid>
                    </Border>

                    <DataGrid x:Name="dgUsers" Grid.Row="1" Background="#1a1a1a" Foreground="White"
                              BorderBrush="#800080" AutoGenerateColumns="False" Margin="0,0,0,10"
                              HeadersVisibility="Column" IsReadOnly="True" SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding UserID}" Width="50"/>
                            <DataGridTextColumn Header="Логин" Binding="{Binding Username}" Width="150"/>
                            <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="200"/>
                            <DataGridTextColumn Header="Роль" Binding="{Binding RoleName}" Width="150"/>
                            <DataGridTextColumn Header="Дата регистрации" Binding="{Binding CreatedAt, StringFormat=dd.MM.yyyy}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
                        <Button x:Name="btnAddUser" Content="➕ ДОБАВИТЬ" Background="#800080" Foreground="White"
                                Padding="15,10" Margin="5" FontSize="12" Cursor="Hand"/>
                        <Button x:Name="btnEditUser" Content="✏ РЕДАКТИРОВАТЬ" Background="#444444" Foreground="White"
                                Padding="15,10" Margin="5" FontSize="12" Cursor="Hand"/>
                        <Button x:Name="btnDeleteUser" Content="🗑 УДАЛИТЬ" Background="#660000" Foreground="White"
                                Padding="15,10" Margin="5" FontSize="12" Cursor="Hand"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="⚰️ ГРОБЫ" Background="#333333" Foreground="White">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DataGrid x:Name="dgCoffins" Grid.Row="0" Background="#1a1a1a" Foreground="White"
                              BorderBrush="#800080" AutoGenerateColumns="False" Margin="0,0,0,10"
                              HeadersVisibility="Column" IsReadOnly="True" SelectionMode="Single"
                              Height="300">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding CoffinID}" Width="50"/>
                            <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="150"/>
                            <DataGridTextColumn Header="Материал" Binding="{Binding Material}" Width="100"/>
                            <DataGridTextColumn Header="Кнопка" Binding="{Binding ButtonText}" Width="100"/>
                            <DataGridTextColumn Header="Цена" Binding="{Binding Price, StringFormat={}{0:C}}" Width="100"/>
                            <DataGridTextColumn Header="Рейтинг" Binding="{Binding Rating}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
                        <Button x:Name="btnAddCoffin" Content="➕ ДОБАВИТЬ ГРОБ" Background="#800080" Foreground="White"
                                Padding="15,10" Margin="5" FontSize="12" Cursor="Hand"/>
                        <Button x:Name="btnEditCoffin" Content="✏ РЕДАКТИРОВАТЬ" Background="#444444" Foreground="White"
                                Padding="15,10" Margin="5" FontSize="12" Cursor="Hand"/>
                        <Button x:Name="btnDeleteCoffin" Content="🗑 УДАЛИТЬ" Background="#660000" Foreground="White"
                                Padding="15,10" Margin="5" FontSize="12" Cursor="Hand"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="📦 ЗАКАЗЫ" Background="#333333" Foreground="White">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#1a1a1a" Padding="10" CornerRadius="5" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <ComboBox x:Name="cmbOrderStatus" Grid.Column="0" Background="#333333" Foreground="White"
                                      BorderBrush="#800080" Height="35">
                                <ComboBoxItem Content="Все статусы"/>
                                <ComboBoxItem Content="Новый"/>
                                <ComboBoxItem Content="В обработке"/>
                                <ComboBoxItem Content="Завершен"/>
                                <ComboBoxItem Content="Отменен"/>
                            </ComboBox>

                            <Button x:Name="btnFilterOrders" Grid.Column="1" Content="ФИЛЬТР" Background="#800080" 
                                    Foreground="White" Padding="15,8" Margin="10,0" FontSize="12" Cursor="Hand"/>

                            <Button x:Name="btnRefreshOrders" Grid.Column="2" Content="ОБНОВИТЬ" Background="#444444" 
                                    Foreground="White" Padding="15,8" Margin="0,0,0,0" FontSize="12" Cursor="Hand"/>
                        </Grid>
                    </Border>

                    <DataGrid x:Name="dgOrders" Grid.Row="1" Background="#1a1a1a" Foreground="White"
                              BorderBrush="#800080" AutoGenerateColumns="False" Margin="0,0,0,10"
                              HeadersVisibility="Column" IsReadOnly="True" SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID заказа" Binding="{Binding OrderID}" Width="80"/>
                            <DataGridTextColumn Header="ID пользователя" Binding="{Binding UserID}" Width="100"/>
                            <DataGridTextColumn Header="Дата" Binding="{Binding OrderDate, StringFormat=dd.MM.yyyy}" Width="100"/>
                            <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="120"/>
                            <DataGridTextColumn Header="Сумма" Binding="{Binding TotalAmount, StringFormat={}{0:C}}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
                        <Button x:Name="btnUpdateOrderStatus" Content="🔄 ИЗМЕНИТЬ СТАТУС" Background="#800080" Foreground="White"
                                Padding="15,10" Margin="5" FontSize="12" Cursor="Hand"/>
                        <Button x:Name="btnViewOrderDetails" Content="📄 ДЕТАЛИ" Background="#444444" Foreground="White"
                                Padding="15,10" Margin="5" FontSize="12" Cursor="Hand"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="🔮 НЕКРОМАНТЫ" Background="#333333" Foreground="White">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DataGrid x:Name="dgNecromancers" Grid.Row="0" Background="#1a1a1a" Foreground="White"
                              BorderBrush="#800080" AutoGenerateColumns="False" Margin="0,0,0,10"
                              HeadersVisibility="Column" IsReadOnly="True" SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding NecromancerID}" Width="50"/>
                            <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="200"/>
                            <DataGridTextColumn Header="Опыт (лет)" Binding="{Binding ExperienceYears}" Width="100"/>
                            <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="120"/>
                            <DataGridTextColumn Header="Дата найма" Binding="{Binding HireDate, StringFormat=dd.MM.yyyy}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
                        <Button x:Name="btnAddNecromancer" Content="➕ ДОБАВИТЬ" Background="#800080" Foreground="White"
                                Padding="15,10" Margin="5" FontSize="12" Cursor="Hand"/>
                        <Button x:Name="btnEditNecromancer" Content="✏ РЕДАКТИРОВАТЬ" Background="#444444" Foreground="White"
                                Padding="15,10" Margin="5" FontSize="12" Cursor="Hand"/>
                        <Button x:Name="btnDeleteNecromancer" Content="🗑 УДАЛИТЬ" Background="#660000" Foreground="White"
                                Padding="15,10" Margin="5" FontSize="12" Cursor="Hand"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="📊 СТАТИСТИКА" Background="#333333" Foreground="White">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#1a1a1a" CornerRadius="10" Padding="15" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="ОБЩАЯ СТАТИСТИКА" Foreground="#800080" FontSize="16" FontWeight="Bold" 
                                       HorizontalAlignment="Center" Margin="0,0,0,15"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                    <TextBlock x:Name="txtTotalUsers" Foreground="White" FontSize="14" Margin="0,5"/>
                                    <TextBlock x:Name="txtTotalCoffins" Foreground="White" FontSize="14" Margin="0,5"/>
                                    <TextBlock x:Name="txtTotalOrders" Foreground="White" FontSize="14" Margin="0,5"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                    <TextBlock x:Name="txtTotalResurrections" Foreground="White" FontSize="14" Margin="0,5"/>
                                    <TextBlock x:Name="txtSuccessResurrections" Foreground="White" FontSize="14" Margin="0,5"/>
                                    <TextBlock x:Name="txtTotalRevenue" Foreground="#800080" FontSize="14" FontWeight="Bold" Margin="0,5"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Button x:Name="btnRefreshStats" Grid.Row="1" Content="ОБНОВИТЬ СТАТИСТИКУ" Background="#800080" 
                            Foreground="White" Padding="15,10" FontSize="14" Cursor="Hand"
                            HorizontalAlignment="Center" Width="200" Margin="0,0,0,15"/>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Page>
