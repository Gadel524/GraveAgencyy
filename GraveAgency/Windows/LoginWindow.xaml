<Window x:Class="GraveAgency.Windows.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GraveAgency.Windows"
        mc:Ignorable="d"
        Title="Гробовое агентство - Вход" Height="450" Width="500"
        WindowStartupLocation="CenterScreen"
        Background="#000000"
        FontFamily="Times New Roman">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="1" Grid.Column="1" Text="ГРОБОВОЕ АГЕНТСТВО" 
                   FontSize="24" FontWeight="Bold" Foreground="#800080"
                   HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <TextBlock Grid.Row="2" Grid.Column="1" Text="с гарантией воскресения" 
                   FontSize="16" Foreground="#666666"
                   HorizontalAlignment="Center" Margin="0,0,0,30"/>

        <Border Grid.Row="3" Grid.Column="1" Background="#1a1a1a" CornerRadius="10" Padding="20" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="ЛОГИН" Foreground="#800080" FontSize="14" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="txtUsername" Background="#333333" Foreground="White" 
                         BorderBrush="#800080" BorderThickness="1" Padding="10" FontSize="14"
                         Margin="0,0,0,15"/>

                <TextBlock Text="ПАРОЛЬ" Foreground="#800080" FontSize="14" FontWeight="Bold" Margin="0,0,0,5"/>
                <PasswordBox x:Name="txtPassword" Background="#333333" Foreground="White" 
                             BorderBrush="#800080" BorderThickness="1" Padding="10" FontSize="14"
                             Margin="0,0,0,20"/>

                <Button x:Name="btnLogin" Content="ВОЙТИ" Background="#800080" Foreground="White"
                        FontSize="16" FontWeight="Bold" Padding="15" Cursor="Hand"
                        BorderThickness="0" Margin="0,0,0,10"/>

                <Button x:Name="btnRegister" Content="РЕГИСТРАЦИЯ" Background="#333333" Foreground="White"
                        FontSize="14" Padding="10" Cursor="Hand" BorderThickness="0"/>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="4" Grid.Column="1" Text="⚰️ Вечный покой с гарантией возврата ⚰️"
                   FontSize="11" Foreground="#444444" HorizontalAlignment="Center" Margin="0,20,0,0"/>
    </Grid>
</Window>
