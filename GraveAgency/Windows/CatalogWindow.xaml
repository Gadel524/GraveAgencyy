<Page x:Class="GraveAgency.Windows.CatalogWindow"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Каталог гробов" Background="#0a0a0a"
      FontFamily="Times New Roman">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="КАТАЛОГ ГРОБОВ" FontSize="24" FontWeight="Bold" 
                   Foreground="#800080" HorizontalAlignment="Center" Margin="0,0,0,15"/>

        <Border Grid.Row="1" Background="#1a1a1a" Padding="10" CornerRadius="5" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="txtSearch" Grid.Column="0" Background="#333333" Foreground="White"
                         BorderBrush="#800080" BorderThickness="1" Padding="8" FontSize="14"/>

                <ComboBox x:Name="cmbMaterial" Grid.Column="1" Width="150" Margin="10,0"
                          Background="#333333" Foreground="Black" BorderBrush="#800080"/>

                <CheckBox x:Name="chkOnlyWithButton" Grid.Column="2" Content="Только с кнопкой Выход"
                          Foreground="White" Margin="10,0" VerticalAlignment="Center"/>

                <Button x:Name="btnSearch" Grid.Column="3" Content="ПОИСК" Background="#800080" 
                        Foreground="White" Padding="15,8" FontSize="12" Cursor="Hand"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="itemsCatalog">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="220" Height="340" Background="#1a1a1a" CornerRadius="10" 
                                Margin="10" BorderBrush="#800080" BorderThickness="1">
                            <Grid Margin="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="⚰️" FontSize="48" Foreground="#800080" 
                                           HorizontalAlignment="Center"/>

                                <TextBlock Grid.Row="1" Text="{Binding Name}" FontSize="16" FontWeight="Bold" 
                                           Foreground="White" HorizontalAlignment="Center" 
                                           TextWrapping="Wrap" Margin="0,5"/>

                                <TextBlock Grid.Row="2" Text="{Binding Material}" FontSize="11" 
                                           Foreground="#888888" HorizontalAlignment="Center"/>

                                <TextBlock Grid.Row="3" Text="{Binding ButtonText}" FontSize="10" 
                                           Foreground="#800080" HorizontalAlignment="Center" Margin="0,5"/>

                                <TextBlock Grid.Row="4" Text="{Binding RatingStars}" FontSize="12" 
                                           Foreground="#FFD700" HorizontalAlignment="Center" 
                                           VerticalAlignment="Center"/>

                                <TextBlock Grid.Row="5" Text="{Binding Price, StringFormat={}{0:C}}" 
                                           FontSize="16" FontWeight="Bold" Foreground="#800080"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
                                    <Button Content="ПОДРОБНЕЕ" Background="#333333" Foreground="White"
                                            Padding="8,5" FontSize="10" Margin="2" Cursor="Hand"
                                            Tag="{Binding}" Click="BtnDetails_Click"/>
                                    <Button x:Name="btnAddToCart" Content="В КОРЗИНУ" Background="#800080" 
                                            Foreground="White" Padding="8,5" FontSize="10" Margin="2" 
                                            Cursor="Hand" Tag="{Binding}" Click="BtnAddToCart_Click"/>
                                    <Button x:Name="btnEdit" Content="РЕД" Background="#444444" 
                                            Foreground="White" Padding="8,5" FontSize="10" Margin="2" 
                                            Cursor="Hand" Tag="{Binding}" Click="BtnEdit_Click"
                                            Visibility="Collapsed"/>
                                    <Button x:Name="btnDelete" Content="УДАЛ" Background="#660000" 
                                            Foreground="White" Padding="8,5" FontSize="10" Margin="2" 
                                            Cursor="Hand" Tag="{Binding}" Click="BtnDelete_Click"
                                            Visibility="Collapsed"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>
