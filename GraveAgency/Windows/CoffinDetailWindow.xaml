<Window x:Class="GraveAgency.Windows.CoffinDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GraveAgency.Windows"
        mc:Ignorable="d"
        Title="Детальная информация о гробе" Height="550" Width="600"
        WindowStartupLocation="CenterScreen"
        Background="#000000"
        FontFamily="Times New Roman">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="⚰️" FontSize="64" Foreground="#800080" 
                   HorizontalAlignment="Center" Margin="0,0,0,10"/>

        <TextBlock x:Name="txtName" Grid.Row="1" FontSize="24" FontWeight="Bold" 
                   Foreground="#800080" HorizontalAlignment="Center" Margin="0,0,0,15"/>

        <Border Grid.Row="2" Background="#1a1a1a" CornerRadius="10" Padding="15" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Материал:" Foreground="#888888" FontSize="14"/>
                <TextBlock x:Name="txtMaterial" Grid.Row="0" Grid.Column="1" Foreground="White" FontSize="14"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Кнопка Выход:" Foreground="#888888" FontSize="14" Margin="0,10,0,0"/>
                <TextBlock x:Name="txtButton" Grid.Row="1" Grid.Column="1" Foreground="#800080" FontSize="14" Margin="0,10,0,0"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Цена:" Foreground="#888888" FontSize="14" Margin="0,10,0,0"/>
                <TextBlock x:Name="txtPrice" Grid.Row="2" Grid.Column="1" Foreground="#800080" FontSize="18" FontWeight="Bold" Margin="0,10,0,0"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Рейтинг:" Foreground="#888888" FontSize="14" Margin="0,10,0,0"/>
                <TextBlock x:Name="txtRating" Grid.Row="3" Grid.Column="1" Foreground="#FFD700" FontSize="14" Margin="0,10,0,0"/>
            </Grid>
        </Border>

        <Border Grid.Row="3" Background="#1a1a1a" CornerRadius="10" Padding="15" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="ОПИСАНИЕ" Foreground="#800080" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                <TextBlock x:Name="txtDescription" Grid.Row="1" Foreground="White" FontSize="13" TextWrapping="Wrap"/>
            </Grid>
        </Border>

        <Border Grid.Row="4" Background="#1a1a1a" CornerRadius="10" Padding="15" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="ИСТОРИЯ ЗАКАЗОВ" Foreground="#800080" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                <ListBox x:Name="lstOrders" Grid.Row="1" Background="#333333" Foreground="White" Height="100" BorderBrush="#800080"/>
            </Grid>
        </Border>

        <Button x:Name="btnClose" Grid.Row="5" Content="ЗАКРЫТЬ" Background="#800080" Foreground="White"
                Padding="15" FontSize="14" FontWeight="Bold" Cursor="Hand" 
                HorizontalAlignment="Center" Width="150" Margin="0,20,0,0"/>
    </Grid>
</Window>
